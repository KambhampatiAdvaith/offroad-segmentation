            if not np.isnan(val):
                plt.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.01,
                        f'{val:.3f}', ha='center', va='bottom', fontsize=9)
        plt.tight_layout()
        plt.savefig(os.path.join(save_dir, 'per_class_iou.png'), dpi=150)
        plt.close()
    print(f"📊 Plots saved → {save_dir}")


def main():
    device = torch.device(DEVICE)
    print(f"🎯 TRAINING FROM SCRATCH (saves backbone + head)")
    print(f"Device: {device}")
    if torch.cuda.is_available():
        print(f"GPU: {torch.cuda.get_device_name()}")
        print(f"VRAM: {torch.cuda.get_device_properties(0).total_mem / 1e9:.1f} GB")

    os.makedirs(SAVE_DIR, exist_ok=True)

    transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
    ])
    mask_transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W), interpolation=transforms.InterpolationMode.NEAREST),
        transforms.ToTensor(),
    ])

    trainset = MaskDataset(TRAIN_DIR, transform, mask_transform, augment=True)
    valset   = MaskDataset(VAL_DIR, transform, mask_transform, augment=False)
    train_loader = DataLoader(trainset, batch_size=BATCH_SIZE, shuffle=True,
                              num_workers=NUM_WORKERS, pin_memory=True, drop_last=True)
    val_loader   = DataLoader(valset, batch_size=BATCH_SIZE, shuffle=False,
                              num_workers=NUM_WORKERS, pin_memory=True)
    print(f"Train: {len(trainset)} images, {len(train_loader)} batches")
    print(f"Val:   {len(valset)} images, {len(val_loader)} batches")

    class_weights = compute_class_weights(TRAIN_DIR, n_classes)

    print(f"\nLoading DINOv2-{BACKBONE_SIZE}...")
    backbone_archs = {"small": "vits14", "base": "vitb14_reg", "large": "vitl14_reg"}
    backbone = torch.hub.load("facebookresearch/dinov2", f"dinov2_{backbone_archs[BACKBONE_SIZE]}")
    backbone.eval().to(device)

    for p in backbone.parameters():
        p.requires_grad = False
    for name, param in backbone.named_parameters():
        if any(f"blocks.{i}." in name for i in [10, 11]):
            param.requires_grad = True

    backbone_params = [p for p in backbone.parameters() if p.requires_grad]
    print(f"  Fine-tuning {sum(p.numel() for p in backbone_params)/1e6:.1f}M backbone params")

    with torch.no_grad():
        dummy = torch.randn(1, 3, IMG_H, IMG_W).to(device)
        n_emb = backbone.forward_features(dummy)["x_norm_patchtokens"].shape[2]
    print(f"Embedding dim: {n_emb}")

    classifier = DeepSegmentationHead(n_emb, n_classes, IMG_W // 14, IMG_H // 14).to(device)

    optimizer = optim.AdamW([
        {'params': list(classifier.parameters()), 'lr': LR_HEAD},
        {'params': backbone_params, 'lr': LR_BACKBONE},
    ], weight_decay=WEIGHT_DECAY)

    total_steps = len(train_loader) * NUM_EPOCHS
    scheduler = optim.lr_scheduler.OneCycleLR(
        optimizer, max_lr=[LR_HEAD, LR_BACKBONE],
        total_steps=total_steps, pct_start=0.1,
        anneal_strategy='cos', div_factor=10, final_div_factor=100
    )

    loss_fn = CombinedLoss(n_classes, class_weights, ce_weight=0.5, dice_weight=0.5).to(device)
    scaler = GradScaler('cuda')

    history = {
        'train_loss': [], 'val_loss': [],
        'train_iou': [], 'val_iou': [],
        'train_dice': [], 'val_dice': [],
        'train_pixel_acc': [], 'val_pixel_acc': [],
        'val_iou_per_class': []
    }

    best_iou = 0.0
    patience_counter = 0
    total_start = time.time()

    print(f"\n{'='*70}")
    print(f"  Training {NUM_EPOCHS} epochs")
    print(f"  LR head: {LR_HEAD}, LR backbone: {LR_BACKBONE}")
    print(f"  Saving backbone + head together")
    print(f"{'='*70}\n")

    for epoch in range(1, NUM_EPOCHS + 1):
        epoch_start = time.time()

        classifier.train(); backbone.train()
        tm = MetricsAccumulator(n_classes)
        for imgs, labels in tqdm(train_loader, desc=f"Ep {epoch}/{NUM_EPOCHS} Train", leave=False):
            imgs = imgs.to(device, non_blocking=True)
            labels = labels.to(device, non_blocking=True).squeeze(1).long()
            optimizer.zero_grad(set_to_none=True)
            with autocast('cuda'):
                tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
                logits = classifier(tokens)
                out = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)
                loss = loss_fn(out, labels)
            scaler.scale(loss).backward()
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(classifier.parameters(), max_norm=1.0)
            torch.nn.utils.clip_grad_norm_(backbone_params, max_norm=0.1)
            scaler.step(optimizer)
            scaler.update()
            scheduler.step()
            with torch.no_grad():
                tm.update(out.detach(), labels, loss.item())

        classifier.eval(); backbone.eval()
        vm = MetricsAccumulator(n_classes)
        with torch.no_grad():
            for imgs, labels in tqdm(val_loader, desc=f"Ep {epoch}/{NUM_EPOCHS} Val", leave=False):
                imgs = imgs.to(device, non_blocking=True)
                labels = labels.to(device, non_blocking=True).squeeze(1).long()
                with autocast('cuda'):
                    tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
                    logits = classifier(tokens)
                    out = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)
                    loss = loss_fn(out, labels)
                vm.update(out, labels, loss.item())

        tr = tm.compute(); vl = vm.compute()
        epoch_time = time.time() - epoch_start

        history['train_loss'].append(tr['loss'])
        history['val_loss'].append(vl['loss'])
        history['train_iou'].append(tr['iou'])
        history['val_iou'].append(vl['iou'])
        history['train_dice'].append(tr['dice'])
        history['val_dice'].append(vl['dice'])
        history['train_pixel_acc'].append(tr['pixel_acc'])
        history['val_pixel_acc'].append(vl['pixel_acc'])
        history['val_iou_per_class'].append(vl['iou_per_class'])

        print(f"\nEpoch {epoch}/{NUM_EPOCHS} ({epoch_time:.0f}s)")
        print(f"  Train -> Loss:{tr['loss']:.4f} IoU:{tr['iou']:.4f} Dice:{tr['dice']:.4f} Acc:{tr['pixel_acc']:.4f}")
        print(f"  Val   -> Loss:{vl['loss']:.4f} IoU:{vl['iou']:.4f} Dice:{vl['dice']:.4f} Acc:{vl['pixel_acc']:.4f}")
        short = ["Bg","Tr","LB","DG","DB","GC","Lg","Rk","Ln","Sk"]
        iou_str = " ".join([f"{short[i]}:{vl['iou_per_class'][i]:.2f}" for i in range(n_classes)])
        print(f"  IoU:  {iou_str}")

        is_best = vl['iou'] > best_iou
        if is_best:
            best_iou = vl['iou']
            patience_counter = 0
        else:
            patience_counter += 1

        save_checkpoint(classifier, backbone, optimizer, scheduler, scaler, epoch, history, best_iou, is_best)

        if patience_counter >= PATIENCE:
            print(f"\nEarly stopping at epoch {epoch}")
            break

    total_time = time.time() - total_start
    print(f"\n{'='*70}")
    print(f"✅ Training complete in {total_time/60:.1f} minutes")
    print(f"🏆 Best Val mIoU: {best_iou:.4f}")
    print(f"{'='*70}")

    save_all_plots(history, SAVE_DIR)


if __name__ == "__main__":
    main()""")


