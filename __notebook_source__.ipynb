    ]
    for ax, (tk, vk, title) in zip(axes.flat, metrics):
        ax.plot(history[tk], label='Train'); ax.plot(history[vk], label='Val')
        ax.set_title(title); ax.set_xlabel('Epoch'); ax.legend(); ax.grid(True)
    plt.tight_layout()
