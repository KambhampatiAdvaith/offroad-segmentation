import torch
import torch.nn.functional as F
import torchvision.transforms as transforms
from torch.cuda.amp import autocast
from torch.utils.data import Dataset, DataLoader
from PIL import Image
import numpy as np
import os
from tqdm import tqdm
import torch.nn as nn

SAVE_DIR  = '/kaggle/working/checkpoints'
VAL_DIR   = '/kaggle/working/Offroad_Segmentation_Training_Dataset/val'
BACKBONE_SIZE = "base"
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

IMG_W = int(((960 / 2) // 14) * 14)
IMG_H = int(((540 / 2) // 14) * 14)

value_map = {
    0: 0, 100: 1, 200: 2, 300: 3, 500: 4,
    550: 5, 700: 6, 800: 7, 7100: 8, 10000: 9
}
n_classes = len(value_map)
CLASS_NAMES = ["Background", "Trees", "Lush Bushes", "Dry Grass", "Dry Bushes",
               "Ground Clutter", "Logs", "Rocks", "Landscape", "Sky"]


class DeepSegmentationHead(nn.Module):
    def __init__(self, in_channels, out_channels, tokenW, tokenH):
        super().__init__()
        self.H, self.W = tokenH, tokenW
        self.stem = nn.Sequential(
            nn.Conv2d(in_channels, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block1 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=7, padding=3, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block2 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=5, padding=2, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block3 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=3, padding=1, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 128, kernel_size=1), nn.BatchNorm2d(128), nn.GELU())
        self.upsample_refine = nn.Sequential(
            nn.ConvTranspose2d(128, 128, kernel_size=2, stride=2), nn.BatchNorm2d(128), nn.GELU(),
            nn.Conv2d(128, 64, kernel_size=3, padding=1), nn.BatchNorm2d(64), nn.GELU())
        self.classifier = nn.Conv2d(64, out_channels, 1)
        self.dropout = nn.Dropout2d(0.1)

    def forward(self, x):
        B, N, C = x.shape
        # DYNAMIC reshape — works for any input size
        H = round((N ** 0.5) * (IMG_H / IMG_W))
        W = N // H
        if H * W != N:
            # Fallback: use original fixed dims
            H, W = self.H, self.W
        x = x.reshape(B, H, W, C).permute(0, 3, 1, 2)
        x = self.stem(x)
        residual = x; x = self.block1(x) + residual
        residual = x; x = self.block2(x) + residual
        x = self.block3(x)
        x = self.upsample_refine(x)
        x = self.dropout(x)
        return self.classifier(x)


def convert_mask(mask):
    arr = np.array(mask)
    new_arr = np.zeros_like(arr, dtype=np.uint8)
    for raw_val, new_val in value_map.items():
        new_arr[arr == raw_val] = new_val
    return Image.fromarray(new_arr)


class MaskDataset(Dataset):
    def __init__(self, data_dir, transform, mask_transform):
        self.image_dir = os.path.join(data_dir, 'Color_Images')
        self.masks_dir = os.path.join(data_dir, 'Segmentation')
        self.transform = transform
        self.mask_transform = mask_transform
        self.data_ids = sorted(os.listdir(self.image_dir))

    def __len__(self):
        return len(self.data_ids)

    def __getitem__(self, idx):
        data_id = self.data_ids[idx]
        image = Image.open(os.path.join(self.image_dir, data_id)).convert("RGB")
        mask = Image.open(os.path.join(self.masks_dir, data_id))
        mask = convert_mask(mask)
        image = self.transform(image)
        mask = self.mask_transform(mask) * 255
        return image, mask


def run_single(backbone, classifier, img):
    \"\"\"Single forward pass — always uses fixed input size\"\"\"
    B, C, H, W = img.shape
    with autocast():
        tokens = backbone.forward_features(img)["x_norm_patchtokens"]
        logits = classifier(tokens)
        out = F.interpolate(logits, size=(H, W), mode="bilinear", align_corners=False)
    return F.softmax(out.float(), dim=1)


def predict_with_tta(backbone, classifier, img, device):
    \"\"\"TTA using only flips (same input size = no reshape crash)\"\"\"
    B, C, H, W = img.shape
    all_probs = []

    # 1. Original
    all_probs.append(run_single(backbone, classifier, img))

    # 2. Horizontal flip
    img_hflip = torch.flip(img, [3])
    out = run_single(backbone, classifier, img_hflip)
    all_probs.append(torch.flip(out, [3]))

    # 3. Vertical flip
    img_vflip = torch.flip(img, [2])
    out = run_single(backbone, classifier, img_vflip)
    all_probs.append(torch.flip(out, [2]))

    # 4. Both flips
    img_both = torch.flip(img, [2, 3])
    out = run_single(backbone, classifier, img_both)
    all_probs.append(torch.flip(out, [2, 3]))

    # Average all predictions
    avg_probs = torch.stack(all_probs, dim=0).mean(dim=0)
    return avg_probs


def main():
    device = torch.device(DEVICE)
    print(f"🎯 TEST-TIME AUGMENTATION (TTA) v2")
    print(f"Device: {device}")

    transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
    ])
    mask_transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W), interpolation=transforms.InterpolationMode.NEAREST),
        transforms.ToTensor(),
    ])

    valset = MaskDataset(VAL_DIR, transform, mask_transform)
    val_loader = DataLoader(valset, batch_size=1, shuffle=False, num_workers=2, pin_memory=True)
    print(f"Val: {len(valset)} images")

    # Load backbone
    print(f"\nLoading DINOv2-{BACKBONE_SIZE}...")
    backbone_archs = {"small": "vits14", "base": "vitb14_reg", "large": "vitl14_reg"}
    backbone = torch.hub.load("facebookresearch/dinov2", f"dinov2_{backbone_archs[BACKBONE_SIZE]}")
    backbone.eval().to(device)

    with torch.no_grad():
        dummy = torch.randn(1, 3, IMG_H, IMG_W).to(device)
        n_emb = backbone.forward_features(dummy)["x_norm_patchtokens"].shape[2]

    # Load classifier — try checkpoint_best.pth first, then segmentation_head_best.pth
    classifier = DeepSegmentationHead(n_emb, n_classes, IMG_W // 14, IMG_H // 14).to(device)

    ckpt_path = os.path.join(SAVE_DIR, 'checkpoint_best.pth')
    head_path = os.path.join(SAVE_DIR, 'segmentation_head_best.pth')

    if os.path.exists(ckpt_path):
        ckpt = torch.load(ckpt_path, map_location=device, weights_only=False)
        classifier.load_state_dict(ckpt['model_state_dict'])
        print(f"✅ Loaded checkpoint (best mIoU: {ckpt['best_iou']:.4f})")
    elif os.path.exists(head_path):
        state = torch.load(head_path, map_location=device, weights_only=False)
        classifier.load_state_dict(state)
        print(f"✅ Loaded head weights")
    else:
        print("❌ No model found!")
        return

    classifier.eval()

    # ═══ WITHOUT TTA ═══
    print(f"\n{'='*60}")
    print("📊 Evaluating WITHOUT TTA...")
    intersection_no = np.zeros(n_classes)
    union_no = np.zeros(n_classes)

    with torch.no_grad():
        for imgs, labels in tqdm(val_loader, desc="No TTA", leave=False):
            imgs = imgs.to(device)
            labels = labels.squeeze(1).long().numpy().flatten()
            probs = run_single(backbone, classifier, imgs)
            preds = torch.argmax(probs, dim=1).cpu().numpy().flatten()
            for c in range(n_classes):
                pc, tc = (preds == c), (labels == c)
                intersection_no[c] += (pc & tc).sum()
                union_no[c] += (pc | tc).sum()

    iou_no = np.zeros(n_classes)
    for c in range(n_classes):
        iou_no[c] = intersection_no[c] / union_no[c] if union_no[c] > 0 else float('nan')
    miou_no = float(np.nanmean(iou_no))

    print(f"\n  WITHOUT TTA mIoU: {miou_no:.4f}")
    for i, name in enumerate(CLASS_NAMES):
        print(f"    {name:20s}: {iou_no[i]:.4f}")

    # ═══ WITH TTA ═══
    print(f"\n{'='*60}")
    print("🚀 Evaluating WITH TTA (4 augmentations)...")
    intersection_tta = np.zeros(n_classes)
    union_tta = np.zeros(n_classes)

    with torch.no_grad():
        for imgs, labels in tqdm(val_loader, desc="With TTA", leave=False):
            imgs = imgs.to(device)
            labels = labels.squeeze(1).long().numpy().flatten()
            avg_probs = predict_with_tta(backbone, classifier, imgs, device)
            preds = torch.argmax(avg_probs, dim=1).cpu().numpy().flatten()
            for c in range(n_classes):
                pc, tc = (preds == c), (labels == c)
                intersection_tta[c] += (pc & tc).sum()
                union_tta[c] += (pc | tc).sum()

    iou_tta = np.zeros(n_classes)
    for c in range(n_classes):
        iou_tta[c] = intersection_tta[c] / union_tta[c] if union_tta[c] > 0 else float('nan')
    miou_tta = float(np.nanmean(iou_tta))

    print(f"\n  WITH TTA mIoU: {miou_tta:.4f}")
    for i, name in enumerate(CLASS_NAMES):
        diff = iou_tta[i] - iou_no[i]
        arrow = "↗️" if diff > 0.005 else "↘️" if diff < -0.005 else "→"
        print(f"    {name:20s}: {iou_tta[i]:.4f}  ({diff:+.4f}) {arrow}")

    print(f"\n{'='*60}")
    print(f"📊 RESULTS:")
    print(f"  WITHOUT TTA: {miou_no:.4f}")
    print(f"  WITH TTA:    {miou_tta:.4f}")
    print(f"  IMPROVEMENT: {miou_tta - miou_no:+.4f}")
    print(f"{'='*60}")


if __name__ == "__main__":
    main()""")


