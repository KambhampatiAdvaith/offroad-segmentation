class DeepSegmentationHead(nn.Module):
    def __init__(self, in_channels, out_channels, tokenW, tokenH):
        super().__init__()
        self.H, self.W = tokenH, tokenW
        self.stem = nn.Sequential(
            nn.Conv2d(in_channels, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block1 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=7, padding=3, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block2 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=5, padding=2, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block3 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=3, padding=1, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 128, kernel_size=1), nn.BatchNorm2d(128), nn.GELU())
        self.upsample_refine = nn.Sequential(
            nn.ConvTranspose2d(128, 128, kernel_size=2, stride=2), nn.BatchNorm2d(128), nn.GELU(),
            nn.Conv2d(128, 64, kernel_size=3, padding=1), nn.BatchNorm2d(64), nn.GELU())
        self.classifier = nn.Conv2d(64, out_channels, 1)
        self.dropout = nn.Dropout2d(0.1)

    def forward(self, x):
        B, N, C = x.shape
        x = x.reshape(B, self.H, self.W, C).permute(0, 3, 1, 2)
        x = self.stem(x)
        residual = x; x = self.block1(x) + residual
        residual = x; x = self.block2(x) + residual
        x = self.block3(x)
        x = self.upsample_refine(x)
        x = self.dropout(x)
        return self.classifier(x)


class CombinedLoss(nn.Module):
    def __init__(self, num_classes=10, class_weights=None, ce_weight=0.5, dice_weight=0.5):
        super().__init__()
        self.ce_weight = ce_weight
        self.dice_weight = dice_weight
        self.num_classes = num_classes
        w = torch.FloatTensor(class_weights) if class_weights else None
        self.ce = nn.CrossEntropyLoss(weight=w)

    def forward(self, logits, targets):
        ce_loss = self.ce(logits, targets)
        probs = F.softmax(logits, dim=1)
        targets_oh = F.one_hot(targets, self.num_classes).permute(0, 3, 1, 2).float()
        dims = (0, 2, 3)
        intersection = (probs * targets_oh).sum(dim=dims)
        union = probs.sum(dim=dims) + targets_oh.sum(dim=dims)
        dice = 1.0 - (2.0 * intersection + 1.0) / (union + 1.0)
        return self.ce_weight * ce_loss + self.dice_weight * dice.mean()


class MetricsAccumulator:
    def __init__(self, num_classes=10):
        self.num_classes = num_classes
        self.reset()

    def reset(self):
        self.intersection = np.zeros(self.num_classes)
        self.union = np.zeros(self.num_classes)
        self.correct = 0
        self.total = 0
        self.losses = []

    def update(self, logits, targets, loss_val):
        preds = torch.argmax(logits, dim=1).view(-1).cpu().numpy()
        tgts = targets.view(-1).cpu().numpy()
        self.correct += (preds == tgts).sum()
        self.total += len(tgts)
        self.losses.append(loss_val)
        for c in range(self.num_classes):
            pc, tc = (preds == c), (tgts == c)
            self.intersection[c] += (pc & tc).sum()
            self.union[c] += (pc | tc).sum()

    def compute(self):
        iou = np.zeros(self.num_classes)
        for c in range(self.num_classes):
            iou[c] = self.intersection[c] / self.union[c] if self.union[c] > 0 else float('nan')
        dice = np.zeros(self.num_classes)
        for c in range(self.num_classes):
            total_c = self.union[c] + self.intersection[c]
            dice[c] = (2 * self.intersection[c] + 1e-6) / (total_c + 1e-6)
        return {
            'loss': float(np.mean(self.losses)) if self.losses else 0,
            'iou': float(np.nanmean(iou)),
            'iou_per_class': iou,
            'dice': float(np.mean(dice)),
            'pixel_acc': float(self.correct / max(self.total, 1))
        }


def compute_class_weights(data_dir, num_classes=10, max_samples=200):
    print("  Computing class weights...")
    masks_dir = os.path.join(data_dir, 'Segmentation')
    mask_files = sorted(os.listdir(masks_dir))[:max_samples]
    pixel_counts = np.zeros(num_classes)
    for fname in tqdm(mask_files, desc="  Scanning", leave=False):
        mask = Image.open(os.path.join(masks_dir, fname))
        arr = np.array(mask)
        new_arr = np.zeros_like(arr, dtype=np.uint8)
        for raw_val, new_val in value_map.items():
            new_arr[arr == raw_val] = new_val
        for c in range(num_classes):
            pixel_counts[c] += (new_arr == c).sum()
    total = pixel_counts.sum()
    freq = pixel_counts / total
    weights = 1.0 / (freq + 1e-6)
    weights = weights / weights.sum() * num_classes
    weights = np.clip(weights, 0.5, 10.0)
    for i, name in enumerate(CLASS_NAMES):
        print(f"    {name:20s}: {freq[i]*100:6.2f}% → weight {weights[i]:.3f}")
    return weights.tolist()


def save_checkpoint(classifier, backbone, optimizer, scheduler, scaler, epoch, history, best_iou, is_best=False):
    \"\"\"NOW SAVES BACKBONE WEIGHTS TOO\"\"\"
    os.makedirs(SAVE_DIR, exist_ok=True)

    # Save fine-tuned backbone layers
    backbone_ft = {}
    for name, param in backbone.named_parameters():
        if param.requires_grad:
            backbone_ft[name] = param.data.clone()

    checkpoint = {
        'epoch': epoch,
        'model_state_dict': classifier.state_dict(),
        'backbone_finetuned': backbone_ft,
        'optimizer_state_dict': optimizer.state_dict(),
        'scheduler_state_dict': scheduler.state_dict() if scheduler else None,
        'scaler_state_dict': scaler.state_dict(),
        'best_iou': best_iou,
        'history': history,
    }
    torch.save(checkpoint, os.path.join(SAVE_DIR, 'checkpoint_latest.pth'))
    if is_best:
        torch.save(checkpoint, os.path.join(SAVE_DIR, 'checkpoint_best.pth'))
        print(f"    💾 BEST model saved! mIoU: {best_iou:.4f}")
    else:
        print(f"    💾 Checkpoint saved (epoch {epoch})")

    h_save = {}
    for k, v in history.items():
        if k == 'val_iou_per_class':
            h_save[k] = [arr.tolist() if isinstance(arr, np.ndarray) else arr for arr in v]
        else:
            h_save[k] = v
    with open(os.path.join(SAVE_DIR, 'history.json'), 'w') as f:
        json.dump(h_save, f, indent=2)


def save_all_plots(history, save_dir):
    os.makedirs(save_dir, exist_ok=True)
    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    metrics = [
        ('train_loss', 'val_loss', 'Loss'),
