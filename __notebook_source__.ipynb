get_ipython().run_cell_magic("writefile", " /kaggle/working/final_eval_fast.py", """\"\"\"
Fast final evaluation: mIoU + simplified mAP50
\"\"\"
import torch
import torch.nn as nn
import torch.nn.functional as F
import torchvision.transforms as transforms
from torch.utils.data import Dataset, DataLoader
from torch.amp import autocast
from PIL import Image
import numpy as np
import os
from tqdm import tqdm

CHECKPOINT_PATH = '/kaggle/working/checkpoints_finetuned_v4/checkpoint_best.pth'
TEST_DIR = '/kaggle/input/datasets/kadvaith/offroad-segmentation-testimages/Offroad_Segmentation_testImages'
DEVICE = "cuda"

value_map = {0: 0, 100: 1, 200: 2, 300: 3, 500: 4, 550: 5, 700: 6, 800: 7, 7100: 8, 10000: 9}
n_classes = len(value_map)
class_names = ['Background', 'Trees', 'Lush Bushes', 'Dry Grass', 'Dry Bushes',
               'Ground Clutter', 'Logs', 'Rocks', 'Landscape', 'Sky']

class DeepSegmentationHead(nn.Module):
    def __init__(self, in_channels, out_channels, tokenW, tokenH):
        super().__init__()
        self.H, self.W = tokenH, tokenW
        self.stem = nn.Sequential(
            nn.Conv2d(in_channels, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block1 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=7, padding=3, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block2 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=5, padding=2, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block3 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=3, padding=1, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 128, kernel_size=1), nn.BatchNorm2d(128), nn.GELU())
        self.upsample_refine = nn.Sequential(
            nn.ConvTranspose2d(128, 128, kernel_size=2, stride=2), nn.BatchNorm2d(128), nn.GELU(),
            nn.Conv2d(128, 64, kernel_size=3, padding=1), nn.BatchNorm2d(64), nn.GELU())
        self.classifier = nn.Conv2d(64, out_channels, 1)
        self.dropout = nn.Dropout2d(0.1)

    def forward(self, x):
        B, N, C = x.shape
        x = x.reshape(B, self.H, self.W, C).permute(0, 3, 1, 2)
        x = self.stem(x)
        residual = x; x = self.block1(x) + residual
        residual = x; x = self.block2(x) + residual
        x = self.block3(x)
        x = self.upsample_refine(x)
        x = self.dropout(x)
        return self.classifier(x)

def convert_mask(mask):
    arr = np.array(mask)
    new_arr = np.zeros_like(arr, dtype=np.uint8)
    for raw, new in value_map.items():
        new_arr[arr == raw] = new
    return Image.fromarray(new_arr)

class MaskDataset(Dataset):
    def __init__(self, data_dir, transform, mask_transform):
        self.image_dir = os.path.join(data_dir, 'Color_Images')
        self.masks_dir = os.path.join(data_dir, 'Segmentation')
        self.transform = transform
        self.mask_transform = mask_transform
        self.data_ids = sorted(os.listdir(self.image_dir))

    def __len__(self):
        return len(self.data_ids)

    def __getitem__(self, idx):
        data_id = self.data_ids[idx]
        image = Image.open(os.path.join(self.image_dir, data_id)).convert("RGB")
        mask = Image.open(os.path.join(self.masks_dir, data_id))
        mask = convert_mask(mask)
        image = self.transform(image)
        mask = self.mask_transform(mask) * 255
        return image, mask


def compute_image_level_ap(all_ious_scores, iou_threshold=0.5):
    \"\"\"
    Compute AP using per-image, per-class IoU as the score.
    Treat each (image, class) as a detection.
    TP if IoU >= threshold, FP otherwise.
    \"\"\"
    all_scores = []
    all_tp = []
    total_gt = 0

    for iou_val, has_gt in all_ious_scores:
        if has_gt:
            total_gt += 1
        if iou_val > 0 or has_gt:  # only count if prediction or GT exists
            all_scores.append(iou_val)
            all_tp.append(1 if iou_val >= iou_threshold else 0)

    if total_gt == 0:
        return float('nan')
    if len(all_scores) == 0:
        return 0.0

    sorted_indices = np.argsort(-np.array(all_scores))
    tp_sorted = np.array(all_tp)[sorted_indices]
    tp_cumsum = np.cumsum(tp_sorted)
    fp_cumsum = np.cumsum(1 - tp_sorted)
    precision = tp_cumsum / (tp_cumsum + fp_cumsum)
    recall = tp_cumsum / total_gt

    mrec = np.concatenate(([0.0], recall, [1.0]))
    mpre = np.concatenate(([1.0], precision, [0.0]))
    for i in range(len(mpre) - 2, -1, -1):
        mpre[i] = max(mpre[i], mpre[i + 1])
    indices = np.where(mrec[1:] != mrec[:-1])[0]
    ap = np.sum((mrec[indices + 1] - mrec[indices]) * mpre[indices + 1])
    return float(ap)


def main():
    device = torch.device(DEVICE)
    print(f"🎯 FAST FINAL EVALUATION — mIoU + mAP50")

    w = int(((960 / 2) // 14) * 14)
    h = int(((540 / 2) // 14) * 14)

    transform = transforms.Compose([
        transforms.Resize((h, w)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
    ])
    mask_transform = transforms.Compose([
        transforms.Resize((h, w), interpolation=transforms.InterpolationMode.NEAREST),
        transforms.ToTensor(),
    ])

    testset = MaskDataset(TEST_DIR, transform, mask_transform)
    test_loader = DataLoader(testset, batch_size=4, shuffle=False, num_workers=2, pin_memory=True)
    print(f"Test images: {len(testset)}")

    # Load model
    backbone = torch.hub.load("facebookresearch/dinov2", "dinov2_vitb14_reg")
    backbone.to(device)

    with torch.no_grad():
        dummy = torch.randn(1, 3, h, w).to(device)
        n_emb = backbone.forward_features(dummy)["x_norm_patchtokens"].shape[2]

    classifier = DeepSegmentationHead(n_emb, n_classes, w // 14, h // 14).to(device)

    ckpt = torch.load(CHECKPOINT_PATH, map_location=device, weights_only=False)
    classifier.load_state_dict(ckpt['model_state_dict'])

    if 'backbone_finetuned' in ckpt:
        backbone_sd = backbone.state_dict()
        for name, param in ckpt['backbone_finetuned'].items():
            if name in backbone_sd:
                backbone_sd[name] = param
        backbone.load_state_dict(backbone_sd)
        print(f"✅ Loaded v4 checkpoint (mIoU: {ckpt['best_iou']:.4f}, epoch: {ckpt['epoch']})")

    backbone.eval()
    classifier.eval()

    # Accumulators
    # mIoU: global pixel counts per class
    global_inter = np.zeros(n_classes, dtype=np.float64)
    global_union = np.zeros(n_classes, dtype=np.float64)

    # mAP50: per-image per-class IoU scores
    ap_data = {c: [] for c in range(n_classes)}  # list of (iou, has_gt)

    # Pixel accuracy
    total_correct = 0
    total_pixels = 0

    # Dice
    global_dice_inter = np.zeros(n_classes, dtype=np.float64)
    global_dice_sum = np.zeros(n_classes, dtype=np.float64)

    print(f"\nRunning inference...")
    with torch.no_grad():
        for imgs, labels in tqdm(test_loader, desc="Evaluating"):
            imgs = imgs.to(device)
            labels = labels.squeeze(1).long().to(device)

            with autocast('cuda'):
                tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
                logits = classifier(tokens)
                out = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)

            preds = torch.argmax(out, dim=1)

            # Per-image metrics for mAP50
            for b in range(imgs.shape[0]):
                pred_b = preds[b].cpu().numpy()
                gt_b = labels[b].cpu().numpy()

                for c in range(n_classes):
                    pred_c = (pred_b == c)
                    gt_c = (gt_b == c)

                    inter = (pred_c & gt_c).sum()
                    union = (pred_c | gt_c).sum()

                    has_gt = gt_c.sum() > 0
                    iou = inter / union if union > 0 else 0.0

                    ap_data[c].append((iou, has_gt))

                    # Global IoU accumulators
                    global_inter[c] += inter
                    global_union[c] += union

                    # Dice accumulators
                    global_dice_inter[c] += inter
                    global_dice_sum[c] += pred_c.sum() + gt_c.sum()

            # Pixel accuracy
            total_correct += (preds == labels).sum().cpu().numpy()
            total_pixels += labels.numel()

    # ---- Compute mIoU ----
    class_iou = []
    for c in range(n_classes):
        if global_union[c] == 0:
            class_iou.append(float('nan'))
        else:
            class_iou.append(global_inter[c] / global_union[c])
    valid_iou = [x for x in class_iou if not np.isnan(x)]
    mean_iou = np.mean(valid_iou)

    # ---- Compute Dice ----
    class_dice = []
    for c in range(n_classes):
        if global_dice_sum[c] == 0:
            class_dice.append(float('nan'))
        else:
            class_dice.append(2 * global_dice_inter[c] / global_dice_sum[c])
    valid_dice = [x for x in class_dice if not np.isnan(x)]
    mean_dice = np.mean(valid_dice)

    # ---- Compute mAP50 ----
    class_ap = []
    for c in range(n_classes):
        ap = compute_image_level_ap(ap_data[c], iou_threshold=0.5)
        class_ap.append(ap)
    valid_ap = [a for a in class_ap if not np.isnan(a)]
    map50 = np.mean(valid_ap) if valid_ap else 0.0

    # Pixel accuracy
    pixel_acc = total_correct / total_pixels

    # ---- Print Results ----
    print(f"\n{'='*65}")
    print(f"  🏆 FINAL TEST RESULTS ({len(testset)} images)")
    print(f"{'='*65}")
    print(f"  {'Class':<20} {'IoU':>8}  {'Dice':>8}  {'AP50':>8}")
    print(f"  {'-'*50}")
    for i, name in enumerate(class_names):
        iou_s = f"{class_iou[i]:.4f}" if not np.isnan(class_iou[i]) else "  N/A"
        dice_s = f"{class_dice[i]:.4f}" if not np.isnan(class_dice[i]) else "  N/A"
        ap_s = f"{class_ap[i]:.4f}" if not np.isnan(class_ap[i]) else "  N/A"
        print(f"  {name:<20} {iou_s:>8}  {dice_s:>8}  {ap_s:>8}")
    print(f"  {'-'*50}")
    print(f"  {'MEAN':<20} {mean_iou:>8.4f}  {mean_dice:>8.4f}  {map50:>8.4f}")
    print(f"{'='*65}")
    print(f"  📊 mIoU:           {mean_iou:.4f}")
    print(f"  📊 mAP50:          {map50:.4f}")
    print(f"  📊 Mean Dice:      {mean_dice:.4f}")
    print(f"  📊 Pixel Accuracy: {pixel_acc:.4f}")
    print(f"{'='*65}")


if __name__ == "__main__":
    main()""")


