SAVE_DIR  = '/kaggle/working/checkpoints'
TRAIN_DIR = '/kaggle/working/Offroad_Segmentation_Training_Dataset/train'
VAL_DIR   = '/kaggle/working/Offroad_Segmentation_Training_Dataset/val'

BATCH_SIZE    = 4
NUM_EPOCHS    = 50
LR_HEAD       = 2e-4
LR_BACKBONE   = 2e-6
WEIGHT_DECAY  = 1e-4
PATIENCE      = 10
BACKBONE_SIZE = "base"

IMG_W = int(((960 / 2) // 14) * 14)
IMG_H = int(((540 / 2) // 14) * 14)
NUM_WORKERS = 2
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

value_map = {
    0: 0, 100: 1, 200: 2, 300: 3, 500: 4,
    550: 5, 700: 6, 800: 7, 7100: 8, 10000: 9
}
n_classes = len(value_map)
CLASS_NAMES = ["Background", "Trees", "Lush Bushes", "Dry Grass", "Dry Bushes",
               "Ground Clutter", "Logs", "Rocks", "Landscape", "Sky"]

def convert_mask(mask):
    arr = np.array(mask)
    new_arr = np.zeros_like(arr, dtype=np.uint8)
    for raw_val, new_val in value_map.items():
        new_arr[arr == raw_val] = new_val
    return Image.fromarray(new_arr)


class MaskDataset(Dataset):
    def __init__(self, data_dir, transform, mask_transform, augment=False):
        self.image_dir = os.path.join(data_dir, 'Color_Images')
        self.masks_dir = os.path.join(data_dir, 'Segmentation')
        self.transform = transform
        self.mask_transform = mask_transform
        self.augment = augment
        self.data_ids = sorted(os.listdir(self.image_dir))

    def __len__(self):
        return len(self.data_ids)

    def __getitem__(self, idx):
        data_id = self.data_ids[idx]
        image = Image.open(os.path.join(self.image_dir, data_id)).convert("RGB")
        mask = Image.open(os.path.join(self.masks_dir, data_id))
        mask = convert_mask(mask)

        if self.augment:
            if torch.rand(1).item() > 0.5:
                image = transforms.functional.hflip(image)
                mask = transforms.functional.hflip(mask)
            if torch.rand(1).item() > 0.8:
                image = transforms.functional.vflip(image)
                mask = transforms.functional.vflip(mask)
            if torch.rand(1).item() > 0.5:
                angle = float(torch.randint(-15, 16, (1,)).item())
                image = transforms.functional.rotate(image, angle,
                         interpolation=transforms.InterpolationMode.BILINEAR, fill=0)
                mask = transforms.functional.rotate(mask, angle,
                         interpolation=transforms.InterpolationMode.NEAREST, fill=0)
            if torch.rand(1).item() > 0.5:
                image = transforms.ColorJitter(
                    brightness=0.3, contrast=0.3, saturation=0.2, hue=0.05)(image)
            if torch.rand(1).item() > 0.7:
                image = transforms.GaussianBlur(kernel_size=5, sigma=(0.1, 2.0))(image)

        image = self.transform(image)
        mask = self.mask_transform(mask) * 255
        return image, mask


class DeepSegmentationHead(nn.Module):
    def __init__(self, in_channels, out_channels, tokenW, tokenH):
        super().__init__()
        self.H, self.W = tokenH, tokenW
        self.stem = nn.Sequential(
            nn.Conv2d(in_channels, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block1 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=7, padding=3, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block2 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=5, padding=2, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block3 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=3, padding=1, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 128, kernel_size=1), nn.BatchNorm2d(128), nn.GELU())
        self.upsample_refine = nn.Sequential(
            nn.ConvTranspose2d(128, 128, kernel_size=2, stride=2), nn.BatchNorm2d(128), nn.GELU(),
            nn.Conv2d(128, 64, kernel_size=3, padding=1), nn.BatchNorm2d(64), nn.GELU())
        self.classifier = nn.Conv2d(64, out_channels, 1)
        self.dropout = nn.Dropout2d(0.1)

    def forward(self, x):
        B, N, C = x.shape
        x = x.reshape(B, self.H, self.W, C).permute(0, 3, 1, 2)
        x = self.stem(x)
        residual = x; x = self.block1(x) + residual
        residual = x; x = self.block2(x) + residual
        x = self.block3(x)
        x = self.upsample_refine(x)
        x = self.dropout(x)
        return self.classifier(x)


class CombinedLoss(nn.Module):
    def __init__(self, num_classes=10, class_weights=None, ce_weight=0.4, dice_weight=0.6):
        super().__init__()
        self.ce_weight = ce_weight
        self.dice_weight = dice_weight
        self.num_classes = num_classes
        w = torch.FloatTensor(class_weights) if class_weights else None
        self.ce = nn.CrossEntropyLoss(weight=w)

    def forward(self, logits, targets):
        ce_loss = self.ce(logits, targets)
        probs = F.softmax(logits, dim=1)
        targets_oh = F.one_hot(targets, self.num_classes).permute(0, 3, 1, 2).float()
        dims = (0, 2, 3)
        intersection = (probs * targets_oh).sum(dim=dims)
        union = probs.sum(dim=dims) + targets_oh.sum(dim=dims)
        dice = 1.0 - (2.0 * intersection + 1.0) / (union + 1.0)
        return self.ce_weight * ce_loss + self.dice_weight * dice.mean()


class MetricsAccumulator:
    def __init__(self, num_classes=10):
        self.num_classes = num_classes
        self.reset()

    def reset(self):
        self.intersection = np.zeros(self.num_classes)
        self.union = np.zeros(self.num_classes)
        self.correct = 0
        self.total = 0
        self.losses = []

    def update(self, logits, targets, loss_val):
        preds = torch.argmax(logits, dim=1).view(-1).cpu().numpy()
        tgts = targets.view(-1).cpu().numpy()
        self.correct += (preds == tgts).sum()
        self.total += len(tgts)
        self.losses.append(loss_val)
        for c in range(self.num_classes):
            pc, tc = (preds == c), (tgts == c)
            self.intersection[c] += (pc & tc).sum()
            self.union[c] += (pc | tc).sum()

    def compute(self):
        iou = np.zeros(self.num_classes)
        for c in range(self.num_classes):
            iou[c] = self.intersection[c] / self.union[c] if self.union[c] > 0 else float('nan')
        dice = np.zeros(self.num_classes)
        for c in range(self.num_classes):
            total_c = self.union[c] + self.intersection[c]
            dice[c] = (2 * self.intersection[c] + 1e-6) / (total_c + 1e-6)
        return {
            'loss': float(np.mean(self.losses)) if self.losses else 0,
            'iou': float(np.nanmean(iou)),
            'iou_per_class': iou,
            'dice': float(np.mean(dice)),
            'pixel_acc': float(self.correct / max(self.total, 1))
        }


def compute_class_weights(data_dir, num_classes=10, max_samples=200):
    print("  Computing class weights...")
    masks_dir = os.path.join(data_dir, 'Segmentation')
    mask_files = sorted(os.listdir(masks_dir))[:max_samples]
    pixel_counts = np.zeros(num_classes)
    for fname in tqdm(mask_files, desc="  Scanning", leave=False):
        mask = Image.open(os.path.join(masks_dir, fname))
        arr = np.array(mask)
        new_arr = np.zeros_like(arr, dtype=np.uint8)
        for raw_val, new_val in value_map.items():
            new_arr[arr == raw_val] = new_val
        for c in range(num_classes):
            pixel_counts[c] += (new_arr == c).sum()
    total = pixel_counts.sum()
    freq = pixel_counts / total
    weights = 1.0 / (freq + 1e-6)
    weights = weights / weights.sum() * num_classes
    weights = np.clip(weights, 0.5, 10.0)
    for i, name in enumerate(CLASS_NAMES):
        print(f"    {name:20s}: {freq[i]*100:6.2f}% → weight {weights[i]:.3f}")
    return weights.tolist()


def save_checkpoint(classifier, optimizer, scheduler, scaler, epoch, history, best_iou, is_best=False):
    os.makedirs(SAVE_DIR, exist_ok=True)
    checkpoint = {
        'epoch': epoch,
        'model_state_dict': classifier.state_dict(),
        'optimizer_state_dict': optimizer.state_dict(),
        'scheduler_state_dict': scheduler.state_dict() if scheduler else None,
        'scaler_state_dict': scaler.state_dict(),
        'best_iou': best_iou,
        'history': history,
    }
    torch.save(checkpoint, os.path.join(SAVE_DIR, 'checkpoint_latest.pth'))
    if is_best:
        torch.save(checkpoint, os.path.join(SAVE_DIR, 'checkpoint_best.pth'))
        torch.save(classifier.state_dict(), os.path.join(SAVE_DIR, 'segmentation_head_best.pth'))
        print(f"    💾 BEST model saved! mIoU: {best_iou:.4f}")
    else:
        print(f"    💾 Checkpoint saved (epoch {epoch})")
    h_save = {}
    for k, v in history.items():
        if k == 'val_iou_per_class':
            h_save[k] = [arr.tolist() if isinstance(arr, np.ndarray) else arr for arr in v]
        else:
            h_save[k] = v
    with open(os.path.join(SAVE_DIR, 'history.json'), 'w') as f:
        json.dump(h_save, f, indent=2)


def save_all_plots(history, save_dir):
    os.makedirs(save_dir, exist_ok=True)
    fig, axes = plt.subplots(2, 2, figsize=(14, 10))
    metrics = [
        ('train_loss', 'val_loss', 'Loss'),
        ('train_iou', 'val_iou', 'Mean IoU'),
        ('train_dice', 'val_dice', 'Dice Score'),
        ('train_pixel_acc', 'val_pixel_acc', 'Pixel Accuracy'),
    ]
    for ax, (tk, vk, title) in zip(axes.flat, metrics):
        ax.plot(history[tk], label='Train'); ax.plot(history[vk], label='Val')
        ax.set_title(title); ax.set_xlabel('Epoch'); ax.legend(); ax.grid(True)
    plt.tight_layout()
    plt.savefig(os.path.join(save_dir, 'all_metrics.png'), dpi=150)
    plt.close()
    if history.get('val_iou_per_class'):
        best_idx = int(np.argmax(history['val_iou']))
        per_class = history['val_iou_per_class'][best_idx]
        if isinstance(per_class, list): per_class = np.array(per_class)
        plt.figure(figsize=(12, 5))
        bars = plt.bar(CLASS_NAMES, per_class, color=plt.cm.Set3(np.linspace(0, 1, n_classes)))
        plt.title(f'Per-Class IoU (Best Epoch {best_idx+1}, mIoU={history["val_iou"][best_idx]:.4f})')
        plt.ylabel('IoU'); plt.xticks(rotation=45, ha='right')
        for bar, val in zip(bars, per_class):
            if not np.isnan(val):
                plt.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.01,
                        f'{val:.3f}', ha='center', va='bottom', fontsize=9)
        plt.tight_layout()
        plt.savefig(os.path.join(save_dir, 'per_class_iou.png'), dpi=150)
        plt.close()
    print(f"Plots saved to {save_dir}")


def main():
    device = torch.device(DEVICE)
    print(f"CONTINUE TRAINING on Kaggle")
    print(f"Device: {device}")
    if torch.cuda.is_available():
        print(f"GPU: {torch.cuda.get_device_name()}")
        print(f"VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB")

    os.makedirs(SAVE_DIR, exist_ok=True)

    transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
    ])
    mask_transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W), interpolation=transforms.InterpolationMode.NEAREST),
        transforms.ToTensor(),
    ])

    trainset = MaskDataset(TRAIN_DIR, transform, mask_transform, augment=True)
    valset   = MaskDataset(VAL_DIR, transform, mask_transform, augment=False)
    train_loader = DataLoader(trainset, batch_size=BATCH_SIZE, shuffle=True,
                              num_workers=NUM_WORKERS, pin_memory=True, drop_last=True)
    val_loader   = DataLoader(valset, batch_size=BATCH_SIZE, shuffle=False,
                              num_workers=NUM_WORKERS, pin_memory=True)
    print(f"Train: {len(trainset)} images, {len(train_loader)} batches")
    print(f"Val:   {len(valset)} images, {len(val_loader)} batches")

    class_weights = compute_class_weights(TRAIN_DIR, n_classes)

    print(f"\nLoading DINOv2-{BACKBONE_SIZE}...")
    backbone_archs = {"small": "vits14", "base": "vitb14_reg", "large": "vitl14_reg"}
    backbone = torch.hub.load("facebookresearch/dinov2", f"dinov2_{backbone_archs[BACKBONE_SIZE]}")
    backbone.eval()
    backbone.to(device)

    for p in backbone.parameters():
        p.requires_grad = False
    for name, param in backbone.named_parameters():
        if any(f"blocks.{i}." in name for i in [10, 11]):
            param.requires_grad = True

    backbone_params = [p for p in backbone.parameters() if p.requires_grad]

    with torch.no_grad():
        dummy = torch.randn(1, 3, IMG_H, IMG_W).to(device)
        n_emb = backbone.forward_features(dummy)["x_norm_patchtokens"].shape[2]
    print(f"Embedding dim: {n_emb}")

    classifier = DeepSegmentationHead(n_emb, n_classes, IMG_W // 14, IMG_H // 14).to(device)

    # ─── LOAD CHECKPOINT ───
    ckpt_path = os.path.join(SAVE_DIR, 'checkpoint_best.pth')
    if os.path.exists(ckpt_path):
        print(f"\nLoading checkpoint...")
        ckpt = torch.load(ckpt_path, map_location=device)
        classifier.load_state_dict(ckpt['model_state_dict'])
        prev_best_iou = ckpt['best_iou']
        start_epoch = ckpt['epoch'] + 1
        prev_history = ckpt.get('history', None)
        print(f"  Loaded! Previous best IoU: {prev_best_iou:.4f}")
        print(f"  Continuing from epoch {start_epoch}")
    else:
        print(f"ERROR: No checkpoint found at {ckpt_path}")
        print(f"Files in {SAVE_DIR}: {os.listdir(SAVE_DIR)}")
        return

    # Fresh optimizer with lower LR
    optimizer = optim.AdamW([
        {'params': list(classifier.parameters()), 'lr': LR_HEAD},
        {'params': backbone_params, 'lr': LR_BACKBONE},
    ], weight_decay=WEIGHT_DECAY)

    remaining_epochs = NUM_EPOCHS - start_epoch + 1
    total_steps = len(train_loader) * remaining_epochs
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=total_steps, eta_min=1e-6)

    loss_fn = CombinedLoss(n_classes, class_weights, ce_weight=0.4, dice_weight=0.6).to(device)
    scaler = GradScaler()

    history = prev_history if prev_history else {
        'train_loss': [], 'val_loss': [],
        'train_iou': [], 'val_iou': [],
        'train_dice': [], 'val_dice': [],
        'train_pixel_acc': [], 'val_pixel_acc': [],
        'val_iou_per_class': []
    }

    best_iou = prev_best_iou
    patience_counter = 0
    total_start = time.time()

    print(f"\n{'='*70}")
    print(f"  Fine-tuning for higher IoU")
    print(f"  Starting IoU: {best_iou:.4f}")
    print(f"  Epochs: {start_epoch} to {NUM_EPOCHS}")
    print(f"  LR head: {LR_HEAD}, LR backbone: {LR_BACKBONE}")
    print(f"  Loss: CE(0.4) + Dice(0.6)")
    print(f"{'='*70}\n")

    for epoch in range(start_epoch, NUM_EPOCHS + 1):
        epoch_start = time.time()

        # TRAIN
        classifier.train(); backbone.train()
        tm = MetricsAccumulator(n_classes)
        for imgs, labels in tqdm(train_loader, desc=f"Ep {epoch}/{NUM_EPOCHS} Train", leave=False):
            imgs = imgs.to(device, non_blocking=True)
            labels = labels.to(device, non_blocking=True).squeeze(1).long()
            optimizer.zero_grad(set_to_none=True)
            with autocast():
                tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
                logits = classifier(tokens)
                out = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)
                loss = loss_fn(out, labels)
            scaler.scale(loss).backward()
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(classifier.parameters(), max_norm=1.0)
            torch.nn.utils.clip_grad_norm_(backbone_params, max_norm=0.1)
            scaler.step(optimizer)
            scaler.update()
            scheduler.step()
            with torch.no_grad():
                tm.update(out.detach(), labels, loss.item())

        # VALIDATE
        classifier.eval(); backbone.eval()
        vm = MetricsAccumulator(n_classes)
        with torch.no_grad():
            for imgs, labels in tqdm(val_loader, desc=f"Ep {epoch}/{NUM_EPOCHS} Val", leave=False):
                imgs = imgs.to(device, non_blocking=True)
                labels = labels.to(device, non_blocking=True).squeeze(1).long()
                with autocast():
                    tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
                    logits = classifier(tokens)
                    out = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)
                    loss = loss_fn(out, labels)
                vm.update(out, labels, loss.item())

        tr = tm.compute(); vl = vm.compute()
        epoch_time = time.time() - epoch_start

        history['train_loss'].append(tr['loss'])
        history['val_loss'].append(vl['loss'])
        history['train_iou'].append(tr['iou'])
        history['val_iou'].append(vl['iou'])
        history['train_dice'].append(tr['dice'])
        history['val_dice'].append(vl['dice'])
        history['train_pixel_acc'].append(tr['pixel_acc'])
        history['val_pixel_acc'].append(vl['pixel_acc'])
        history['val_iou_per_class'].append(vl['iou_per_class'])

        print(f"\nEpoch {epoch}/{NUM_EPOCHS} ({epoch_time:.0f}s)")
        print(f"  Train -> Loss:{tr['loss']:.4f} IoU:{tr['iou']:.4f} Dice:{tr['dice']:.4f} Acc:{tr['pixel_acc']:.4f}")
        print(f"  Val   -> Loss:{vl['loss']:.4f} IoU:{vl['iou']:.4f} Dice:{vl['dice']:.4f} Acc:{vl['pixel_acc']:.4f}")
        short = ["Bg","Tr","LB","DG","DB","GC","Lg","Rk","Ln","Sk"]
        iou_str = " ".join([f"{short[i]}:{vl['iou_per_class'][i]:.2f}" for i in range(n_classes)])
        print(f"  IoU:  {iou_str}")

        is_best = vl['iou'] > best_iou
        if is_best:
            best_iou = vl['iou']
            patience_counter = 0
        else:
            patience_counter += 1

        save_checkpoint(classifier, optimizer, scheduler, scaler, epoch, history, best_iou, is_best)

        if patience_counter >= PATIENCE:
            print(f"\nEarly stopping at epoch {epoch}")
            break

    total_time = time.time() - total_start
    print(f"\n{'='*70}")
    print(f"Training complete in {total_time/60:.1f} minutes")
    print(f"Best Val mIoU: {best_iou:.4f}")
    print(f"{'='*70}")

    save_all_plots(history, SAVE_DIR)
    torch.save(classifier.state_dict(), os.path.join(SAVE_DIR, 'segmentation_head_final.pth'))
    print(f"\nDownload model from: Output tab (right sidebar)")


if __name__ == "__main__":
    main()""")


