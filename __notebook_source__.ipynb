    all_class_iou = []

    with torch.no_grad():
        pbar = tqdm(test_loader, desc="TTA Testing")
        for imgs, labels, data_ids in pbar:
            imgs = imgs.to(device)
            labels_squeezed = labels.squeeze(1).long()

            # Original
            tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
            logits = classifier(tokens)
            out1 = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)
            probs1 = F.softmax(out1.float(), dim=1)

            # Horizontal flip
            imgs_flip = torch.flip(imgs, dims=[3])
            tokens_flip = backbone.forward_features(imgs_flip)["x_norm_patchtokens"]
            logits_flip = classifier(tokens_flip)
            out2 = F.interpolate(logits_flip, size=imgs.shape[2:], mode="bilinear", align_corners=False)
            out2 = torch.flip(out2, dims=[3])  # flip back
            probs2 = F.softmax(out2.float(), dim=1)

            # Average probabilities
            avg_probs = (probs1 + probs2) / 2.0
            predicted = torch.argmax(avg_probs, dim=1)

            iou, class_iou = compute_iou(predicted, labels_squeezed, num_classes=n_classes)
            iou_scores.append(iou)
            all_class_iou.append(class_iou)

            # Save predictions
            for i in range(imgs.shape[0]):
                data_id = data_ids[i]
                base_name = os.path.splitext(data_id)[0]
                pred_mask = predicted[i].cpu().numpy().astype(np.uint8)
                Image.fromarray(pred_mask).save(os.path.join(masks_dir, f'{base_name}_pred.png'))

            pbar.set_postfix(iou=f"{iou:.3f}")

    mean_iou = np.nanmean(iou_scores)
    avg_class_iou = np.nanmean(all_class_iou, axis=0)

    print(f"\n{'='*60}")
    print(f"  TEST RESULTS (with TTA)")
    print(f"{'='*60}")
    print(f"  Mean IoU: {mean_iou:.4f}")
    print(f"{'='*60}")
    for i, name in enumerate(class_names):
        iou_str = f"{avg_class_iou[i]:.4f}" if not np.isnan(avg_class_iou[i]) else "N/A"
        print(f"  {name:<20}: {iou_str}")
    print(f"{'='*60}")

if __name__ == "__main__":
    main()""")


