import torch
import torch.nn.functional as F
import torchvision.transforms as transforms
from torch.amp import autocast
from torch.utils.data import Dataset, DataLoader
from PIL import Image
import numpy as np
import os
from tqdm import tqdm
import torch.nn as nn

SAVE_DIR  = '/kaggle/working/checkpoints_v2'
VAL_DIR   = '/kaggle/working/Offroad_Segmentation_Training_Dataset/val'
BACKBONE_SIZE = "base"
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

IMG_W = int(((960 / 2) // 14) * 14)
IMG_H = int(((540 / 2) // 14) * 14)

value_map = {
    0: 0, 100: 1, 200: 2, 300: 3, 500: 4,
    550: 5, 700: 6, 800: 7, 7100: 8, 10000: 9
}
n_classes = len(value_map)
CLASS_NAMES = ["Background", "Trees", "Lush Bushes", "Dry Grass", "Dry Bushes",
               "Ground Clutter", "Logs", "Rocks", "Landscape", "Sky"]


class DeepSegmentationHead(nn.Module):
    def __init__(self, in_channels, out_channels, tokenW, tokenH):
        super().__init__()
        self.H, self.W = tokenH, tokenW
        self.stem = nn.Sequential(
            nn.Conv2d(in_channels, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block1 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=7, padding=3, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block2 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=5, padding=2, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 256, kernel_size=1), nn.BatchNorm2d(256), nn.GELU())
        self.block3 = nn.Sequential(
            nn.Conv2d(256, 256, kernel_size=3, padding=1, groups=256), nn.BatchNorm2d(256), nn.GELU(),
            nn.Conv2d(256, 128, kernel_size=1), nn.BatchNorm2d(128), nn.GELU())
        self.upsample_refine = nn.Sequential(
            nn.ConvTranspose2d(128, 128, kernel_size=2, stride=2), nn.BatchNorm2d(128), nn.GELU(),
            nn.Conv2d(128, 64, kernel_size=3, padding=1), nn.BatchNorm2d(64), nn.GELU())
        self.classifier = nn.Conv2d(64, out_channels, 1)
        self.dropout = nn.Dropout2d(0.1)

    def forward(self, x):
        B, N, C = x.shape
        x = x.reshape(B, self.H, self.W, C).permute(0, 3, 1, 2)
        x = self.stem(x)
        residual = x; x = self.block1(x) + residual
        residual = x; x = self.block2(x) + residual
        x = self.block3(x)
        x = self.upsample_refine(x)
        x = self.dropout(x)
        return self.classifier(x)


def convert_mask(mask):
    arr = np.array(mask)
    new_arr = np.zeros_like(arr, dtype=np.uint8)
    for raw_val, new_val in value_map.items():
        new_arr[arr == raw_val] = new_val
    return Image.fromarray(new_arr)


class MaskDataset(Dataset):
    def __init__(self, data_dir, transform, mask_transform):
        self.image_dir = os.path.join(data_dir, 'Color_Images')
        self.masks_dir = os.path.join(data_dir, 'Segmentation')
        self.transform = transform
        self.mask_transform = mask_transform
        self.data_ids = sorted(os.listdir(self.image_dir))

    def __len__(self):
        return len(self.data_ids)

    def __getitem__(self, idx):
        data_id = self.data_ids[idx]
        image = Image.open(os.path.join(self.image_dir, data_id)).convert("RGB")
        mask = Image.open(os.path.join(self.masks_dir, data_id))
        mask = convert_mask(mask)
        image = self.transform(image)
        mask = self.mask_transform(mask) * 255
        return image, mask


def compute_ap_per_class(pred_masks, gt_masks, pred_scores, iou_threshold=0.5):
    \"\"\"
    Compute AP at a given IoU threshold for one class.
    Each connected component in prediction/GT is treated as a detection.
    \"\"\"
    from scipy import ndimage
    
    all_scores = []
    all_tp = []
    total_gt = 0
    
    for pred_mask, gt_mask, score_map in zip(pred_masks, gt_masks, pred_scores):
        # Find connected components in GT
        gt_labeled, n_gt = ndimage.label(gt_mask)
        total_gt += n_gt
        
        # Find connected components in prediction
        pred_labeled, n_pred = ndimage.label(pred_mask)
        
        matched_gt = set()
        detections = []
        
        for p in range(1, n_pred + 1):
            pred_region = (pred_labeled == p)
            avg_score = score_map[pred_region].mean()
            
            best_iou = 0
            best_gt = -1
            for g in range(1, n_gt + 1):
                if g in matched_gt:
                    continue
                gt_region = (gt_labeled == g)
                intersection = (pred_region & gt_region).sum()
                union = (pred_region | gt_region).sum()
                iou = intersection / union if union > 0 else 0
                if iou > best_iou:
                    best_iou = iou
                    best_gt = g
            
            if best_iou >= iou_threshold and best_gt not in matched_gt:
                detections.append((avg_score, 1))  # TP
                matched_gt.add(best_gt)
            else:
                detections.append((avg_score, 0))  # FP
        
        all_scores.extend([d[0] for d in detections])
        all_tp.extend([d[1] for d in detections])
    
    if total_gt == 0:
        return float('nan')
    
    if len(all_scores) == 0:
        return 0.0
    
    # Sort by score descending
    sorted_indices = np.argsort(-np.array(all_scores))
    tp_sorted = np.array(all_tp)[sorted_indices]
    
    tp_cumsum = np.cumsum(tp_sorted)
    fp_cumsum = np.cumsum(1 - tp_sorted)
    
    precision = tp_cumsum / (tp_cumsum + fp_cumsum)
    recall = tp_cumsum / total_gt
    
    # AP using all-point interpolation
    mrec = np.concatenate(([0.0], recall, [1.0]))
    mpre = np.concatenate(([1.0], precision, [0.0]))
    
    for i in range(len(mpre) - 2, -1, -1):
        mpre[i] = max(mpre[i], mpre[i + 1])
    
    indices = np.where(mrec[1:] != mrec[:-1])[0]
    ap = np.sum((mrec[indices + 1] - mrec[indices]) * mpre[indices + 1])
    
    return float(ap)


def main():
    device = torch.device(DEVICE)
    print(f"🎯 Computing mAP50")
    print(f"Device: {device}")

    transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])
    ])
    mask_transform = transforms.Compose([
        transforms.Resize((IMG_H, IMG_W), interpolation=transforms.InterpolationMode.NEAREST),
        transforms.ToTensor(),
    ])

    valset = MaskDataset(VAL_DIR, transform, mask_transform)
    val_loader = DataLoader(valset, batch_size=1, shuffle=False, num_workers=2, pin_memory=True)
    print(f"Val: {len(valset)} images")

    # Load model
    print(f"\nLoading DINOv2-{BACKBONE_SIZE}...")
    backbone_archs = {"small": "vits14", "base": "vitb14_reg", "large": "vitl14_reg"}
    backbone = torch.hub.load("facebookresearch/dinov2", f"dinov2_{backbone_archs[BACKBONE_SIZE]}")
    backbone.to(device)

    with torch.no_grad():
        dummy = torch.randn(1, 3, IMG_H, IMG_W).to(device)
        n_emb = backbone.forward_features(dummy)["x_norm_patchtokens"].shape[2]

    classifier = DeepSegmentationHead(n_emb, n_classes, IMG_W // 14, IMG_H // 14).to(device)

    ckpt = torch.load(os.path.join(SAVE_DIR, 'checkpoint_best.pth'), map_location=device, weights_only=False)
    classifier.load_state_dict(ckpt['model_state_dict'])

    if 'backbone_finetuned' in ckpt:
        backbone_ft = ckpt['backbone_finetuned']
        backbone_sd = backbone.state_dict()
        for name, param in backbone_ft.items():
            if name in backbone_sd:
                backbone_sd[name] = param
        backbone.load_state_dict(backbone_sd)
        print(f"✅ Loaded backbone + head (best mIoU: {ckpt['best_iou']:.4f})")

    backbone.eval()
    classifier.eval()

    # Collect predictions per class
    from scipy import ndimage
    
    pred_masks_per_class = {c: [] for c in range(n_classes)}
    gt_masks_per_class = {c: [] for c in range(n_classes)}
    score_maps_per_class = {c: [] for c in range(n_classes)}

    print(f"\nRunning inference...")
    with torch.no_grad():
        for imgs, labels in tqdm(val_loader, desc="Inference", leave=False):
            imgs = imgs.to(device)
            labels = labels.squeeze(1).long()

            with autocast('cuda'):
                tokens = backbone.forward_features(imgs)["x_norm_patchtokens"]
                logits = classifier(tokens)
                out = F.interpolate(logits, size=imgs.shape[2:], mode="bilinear", align_corners=False)

            probs = F.softmax(out.float(), dim=1)  # [B, C, H, W]
            preds = torch.argmax(probs, dim=1)     # [B, H, W]

            for b in range(imgs.shape[0]):
                for c in range(n_classes):
                    pred_c = (preds[b] == c).cpu().numpy().astype(bool)
                    gt_c = (labels[b] == c).numpy().astype(bool)
                    score_c = probs[b, c].cpu().numpy()
                    
                    pred_masks_per_class[c].append(pred_c)
                    gt_masks_per_class[c].append(gt_c)
                    score_maps_per_class[c].append(score_c)

    # Compute AP per class
    print(f"\nComputing mAP50...")
    print(f"{'='*60}")
    
    aps = []
    for c in range(n_classes):
        ap = compute_ap_per_class(
            pred_masks_per_class[c],
            gt_masks_per_class[c],
            score_maps_per_class[c],
            iou_threshold=0.5
        )
        aps.append(ap)
        status = f"{ap:.4f}" if not np.isnan(ap) else "N/A (no GT)"
        print(f"  {CLASS_NAMES[c]:20s}: AP50 = {status}")

    valid_aps = [a for a in aps if not np.isnan(a)]
    map50 = float(np.mean(valid_aps)) if valid_aps else 0.0

    print(f"{'='*60}")
    print(f"  📊 mIoU:  {ckpt['best_iou']:.4f}")
    print(f"  🏆 mAP50: {map50:.4f}")
    print(f"{'='*60}")


if __name__ == "__main__":
    main()""")


